---
---
<div class="quality-notice" id="quality-notice">
  <div class="qn-icon" id="qn-icon"></div>
  <div class="qn-text">
    <span class="qn-title" id="qn-title"></span>
    <span class="qn-desc" id="qn-desc"></span>
  </div>
</div>

<style>
/* Quality notice */
.quality-notice {
  margin-top: 1.25rem;
  border-radius: var(--r);
  padding: 16px 18px;
  display: flex;
  align-items: flex-start;
  gap: 14px;
  border: 1px solid transparent; /* Defaults */
  background: white;
  box-shadow: var(--sh-1);
}

.quality-notice.clean { border-color: rgba(22,163,74,0.18); background: rgba(22,163,74,0.03); }
.quality-notice.balanced { border-color: rgba(0,107,94,0.18); background: rgba(0,107,94,0.03); }
.quality-notice.indulgent { border-color: rgba(184,146,74,0.25); background: rgba(184,146,74,0.04); }

.qn-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  background: white;
  border: 1px solid transparent;
}
.quality-notice.clean .qn-icon { border-color: rgba(22,163,74,0.2); }
.quality-notice.balanced .qn-icon { border-color: rgba(0,107,94,0.2); }
.quality-notice.indulgent .qn-icon { border-color: rgba(184,146,74,0.25); }

.qn-text { flex: 1; }
.qn-title {
  font-family: var(--font-serif);
  font-size: 17px;
  font-weight: 500;
  color: var(--ink);
  display: block;
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}
.qn-desc {
  font-size: 14.5px;
  line-height: 1.65;
  color: var(--ink-60);
}

@media print {
  .quality-notice { box-shadow: none !important; border: 1px solid var(--cream-200); }
}
</style>
