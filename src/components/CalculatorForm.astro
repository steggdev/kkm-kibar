---
---
<div class="form-card">
  <!-- Section 01: Personal -->
  <div class="form-section">
    <div class="section-head">
      <span class="section-number" id="s1-num">i.</span>
      <span class="section-label" id="l-personal">Maklumat Peribadi</span>
      <span class="section-line"></span>
    </div>
    <div class="field-row">
      <div class="field">
        <label id="l-weight">berat badan semasa</label>
        <div class="input-wrap">
          <input type="number" id="weight" placeholder="65.5" step="0.1" min="20" max="300" />
          <span class="input-unit">kg</span>
        </div>
      </div>
      <div class="field">
        <label id="l-height">tinggi badan</label>
        <div class="input-wrap">
          <input type="number" id="height" placeholder="165" step="1" min="100" max="250" />
          <span class="input-unit">cm</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 02: Activity -->
  <div class="form-section">
    <div class="section-head">
      <span class="section-number" id="s2-num">ii.</span>
      <span class="section-label" id="l-activity">Tahap Aktiviti Fizikal</span>
      <span class="section-line"></span>
    </div>
    <div class="activity-grid" id="activity-options">
      <div class="activity-opt selected" data-level="sedentary">
        <div class="act-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="act-icon">🪑</div>
        <div class="act-label" id="a1-label">Sedentari</div>
        <div class="act-desc" id="a1-desc">Kerja pejabat, duduk banyak</div>
      </div>
      <div class="activity-opt" data-level="moderate">
        <div class="act-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="act-icon">🚶</div>
        <div class="act-label" id="a2-label">Sederhana Aktif</div>
        <div class="act-desc" id="a2-desc">Senaman 3–5x seminggu</div>
      </div>
      <div class="activity-opt" data-level="active">
        <div class="act-check">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="act-icon">🏃</div>
        <div class="act-label" id="a3-label">Sangat Aktif</div>
        <div class="act-desc" id="a3-desc">Kerja fizikal / latihan berat</div>
      </div>
    </div>
  </div>

  <!-- Section 03: Timing -->
  <div class="form-section">
    <div class="section-head">
      <span class="section-number" id="s3-num">iii.</span>
      <span class="section-label" id="l-timing">Waktu Makan Biasa Anda</span>
      <span class="section-line"></span>
    </div>
    <div class="timing-grid">
      <div class="timing-slot">
        <label class="timing-label">
          <span class="timing-label-emoji">🌅</span>
          <span id="lt-breakfast">sarapan</span>
        </label>
        <select class="timing-select" id="t-breakfast">
          <option value="6:00">6:00 pagi</option>
          <option value="6:30">6:30 pagi</option>
          <option value="7:00" selected>7:00 pagi</option>
          <option value="7:30">7:30 pagi</option>
          <option value="8:00">8:00 pagi</option>
          <option value="8:30">8:30 pagi</option>
          <option value="9:00">9:00 pagi</option>
          <option value="9:30">9:30 pagi</option>
          <option value="10:00">10:00 pagi</option>
        </select>
      </div>
      <div class="timing-slot">
        <label class="timing-label">
          <span class="timing-label-emoji">☀️</span>
          <span id="lt-lunch">makan tengahari</span>
        </label>
        <select class="timing-select" id="t-lunch">
          <option value="11:30">11:30 pagi</option>
          <option value="12:00">12:00 tengahari</option>
          <option value="12:30" selected>12:30 tengahari</option>
          <option value="13:00">1:00 petang</option>
          <option value="13:30">1:30 petang</option>
          <option value="14:00">2:00 petang</option>
        </select>
      </div>
      <div class="timing-slot">
        <label class="timing-label">
          <span class="timing-label-emoji">🌙</span>
          <span id="lt-dinner">makan malam</span>
        </label>
        <select class="timing-select" id="t-dinner">
          <option value="18:00">6:00 petang</option>
          <option value="18:30">6:30 petang</option>
          <option value="19:00" selected>7:00 malam</option>
          <option value="19:30">7:30 malam</option>
          <option value="20:00">8:00 malam</option>
          <option value="20:30">8:30 malam</option>
          <option value="21:00">9:00 malam</option>
        </select>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-section">
    <button class="calc-btn" id="calc-btn">
      <span class="calc-btn-content">
        <span id="calc-btn-text">Kira Keputusan</span>
        <span class="calc-btn-arrow">→</span>
      </span>
    </button>
  </div>
</div>

<style>
.form-card {
  background: white;
  border-radius: var(--r-lg);
  box-shadow: var(--sh-4);
  overflow: hidden;
  border: 1px solid rgba(0,36,31,0.03);
  animation: fadeInUp 0.8s var(--ease) 0.5s both;
}

/* Section header */
.form-section {
  padding: 2rem;
  border-bottom: 1px solid var(--cream-100);
  position: relative;
}

.form-section:last-of-type { border-bottom: none; }

.section-head {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 1.5rem;
}

.section-number {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 15px;
  color: var(--teal-700);
  letter-spacing: 0.5px;
}

.section-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, var(--cream-200), transparent);
}

.section-label {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--ink-40);
}

/* Fields */
.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.field label {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 15px;
  font-weight: 400;
  color: var(--ink-60);
}

.input-wrap {
  position: relative;
}

.field input[type="number"] {
  width: 100%;
  height: 56px;
  padding: 0 52px 0 18px;
  border: 1px solid var(--cream-200);
  border-radius: var(--r);
  font-family: var(--font-serif);
  font-size: 26px;
  font-weight: 400;
  color: var(--ink);
  background: var(--cream);
  transition: all 0.3s var(--ease);
  -moz-appearance: textfield;
  letter-spacing: -0.01em;
}

.field input[type="number"]::-webkit-inner-spin-button,
.field input[type="number"]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }

.field input[type="number"]:focus {
  outline: none;
  border-color: var(--teal-700);
  box-shadow: 0 0 0 4px rgba(0,107,94,0.08);
  background: white;
}

.field input[type="number"]::placeholder {
  font-size: 19px;
  color: var(--ink-20);
  font-weight: 300;
  font-family: var(--font-sans);
}

.input-unit {
  position: absolute;
  right: 18px;
  top: 50%;
  transform: translateY(-50%);
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 15px;
  font-weight: 400;
  color: var(--ink-40);
  pointer-events: none;
  letter-spacing: 0.5px;
}

/* Activity */
.activity-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.activity-opt {
  position: relative;
  border: 1px solid var(--cream-200);
  border-radius: var(--r);
  padding: 18px 12px 16px;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s var(--ease);
  background: var(--cream);
  overflow: hidden;
}

.activity-opt::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, rgba(0,107,94,0.05) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.3s var(--ease);
}

.activity-opt:hover {
  border-color: var(--teal-400);
  transform: translateY(-1px);
}
.activity-opt:hover::before { opacity: 1; }

.activity-opt.selected {
  border-color: var(--teal-700);
  background: white;
  box-shadow: 0 0 0 3px rgba(0,107,94,0.06);
}
.activity-opt.selected::before { opacity: 1; }

.activity-opt.selected .act-check {
  opacity: 1;
  transform: scale(1);
}

.act-check {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--teal-700);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.5);
  transition: all 0.3s var(--ease);
}

.act-check svg { width: 10px; height: 10px; color: white; }

.act-icon {
  font-size: 24px;
  margin-bottom: 10px;
  filter: saturate(0.9);
}

.act-label {
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 4px;
  position: relative;
}

.act-desc {
  font-size: 12.5px;
  color: var(--ink-40);
  line-height: 1.45;
  position: relative;
}

/* Timing */
.timing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.timing-slot { display: flex; flex-direction: column; gap: 8px; }

.timing-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-serif);
  font-style: italic;
  font-size: 15px;
  font-weight: 400;
  color: var(--ink-60);
}

.timing-label-emoji { font-size: 16px; }

.timing-select {
  width: 100%;
  height: 44px;
  padding: 0 36px 0 14px;
  border: 1px solid var(--cream-200);
  border-radius: var(--r);
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 500;
  color: var(--ink);
  background-color: var(--cream);
  cursor: pointer;
  appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%237a9693' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' fill='none'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 14px center;
  transition: all 0.3s var(--ease);
}

.timing-select:focus {
  outline: none;
  border-color: var(--teal-700);
  background-color: white;
  box-shadow: 0 0 0 4px rgba(0,107,94,0.08);
}

/* CTA */
.cta-section {
  padding: 1.75rem 2rem 2rem;
  background: linear-gradient(180deg, transparent 0%, var(--cream) 100%);
}

.calc-btn {
  width: 100%;
  height: 58px;
  background: var(--teal-900);
  color: white;
  border: none;
  border-radius: var(--r);
  font-family: var(--font-sans);
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.4s var(--ease);
  box-shadow: 0 6px 20px -6px rgba(0,36,31,0.5);
}

.calc-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--teal-700) 0%, var(--teal-900) 100%);
  opacity: 0;
  transition: opacity 0.4s var(--ease);
}

.calc-btn-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.calc-btn-arrow {
  display: inline-block;
  transition: transform 0.4s var(--ease);
}

.calc-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 30px -8px rgba(0,36,31,0.55);
}
.calc-btn:hover::before { opacity: 1; }
.calc-btn:hover .calc-btn-arrow { transform: translateX(4px); }
.calc-btn:active { transform: translateY(0); }

@media print {
  .form-card { display: none; }
}

@media (max-width: 560px) {
  .form-section { padding: 1.5rem; }
  .field-row { grid-template-columns: 1fr; }
  .activity-grid { grid-template-columns: 1fr; text-align: left; display: flex; flex-direction: column; }
  .activity-opt { text-align: left; padding: 14px 16px; display: flex; align-items: center; gap: 12px; }
  .act-icon { margin: 0; }
  .timing-grid { grid-template-columns: 1fr; }
}
</style>
